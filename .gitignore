# Ignore all Markdown files
*.md
**/*.md

# Keep the root README tracked
!README.md
node_modules

# Environment files
.env
.env.local
.env.*.local
!.env.example
*.sql

# Build output and caches
dist/
.vite/
coverage/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS and editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local database and backup artifacts
*.sqlite
*.sqlite3
*.db
*.db-*
*.bak
*.dump

# Secrets, keys, and certificates
*.pem
*.key
*.p12
*.pfx
*.crt
secrets.*
*.secret
